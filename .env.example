# Recipients compiled into the Huff bytecode and passed to the Solidity baseline.
RECIPIENT_A=0x0000000000000000000000000000000000001001
RECIPIENT_B=0x0000000000000000000000000000000000001002
RECIPIENT_C=0x0000000000000000000000000000000000001003

# RPC used by the deployment wrapper. ETH_RPC_URL is also accepted.
RPC_URL=http://127.0.0.1:8545

# Deployment profile.
SPLIT_PROFILE=core

# Optional reusable factory address. If omitted, deploy.mjs will deploy a new factory.
# INVARIANT_SPLIT_FACTORY=0x...

# Preferred wallet setup: Foundry keystore.
ETH_KEYSTORE_ACCOUNT=invariantsplit-deployer
ETH_PASSWORD=.secrets/invariantsplit.password

# Optional raw-key fallback.
# PRIVATE_KEY=0x...

# Optional explorer verification.
AUTO_VERIFY=true
VERIFIER=etherscan
ETHERSCAN_API_KEY=

# Optional explorer base URL used in published markdown.
# EXPLORER_URL=https://sepolia.etherscan.io
